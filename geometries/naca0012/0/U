FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (1 0 0);

boundaryField
{
    inlet
    {
        type            freestream;
        freestreamValue uniform (1 0 0);
    }
    outlet
    {
        type            freestream;
        freestreamValue uniform (1 0 0);
    }
    airfoil
    {
        type            noSlip;
    }
    top
    {
        type            freestream;
        freestreamValue uniform (1 0 0);
    }
    bottom
    {
        type            freestream;
        freestreamValue uniform (1 0 0);
    }
    frontAndBack
    {
        type            empty;
    }
}
